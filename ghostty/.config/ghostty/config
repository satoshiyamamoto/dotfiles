# Ghostty Configuration

## Options
font-family = Operator Mono SSm Lig
font-family = Symbols Nerd Font Mono
font-family = Hiragino Kaku Gothic ProN
font-feature = -dlig
font-size = 12
font-codepoint-map = U+1FBF0-U+1FBF9=Noto Sans Symbols 2
title = " "
adjust-cell-width = 0
adjust-cell-height = 11
adjust-underline-position = 2
adjust-strikethrough-position = 2
mouse-hide-while-typing = true
window-padding-balance = true
window-padding-color = extend
window-colorspace = display-p3
background-opacity = 0.95
background-opacity-cells = true
unfocused-split-opacity = 0.85
macos-titlebar-proxy-icon = hidden
macos-option-as-alt = true

## Theme
config-file = ?auto/theme.ghostty

## Shaders
custom-shader = shaders/ghostty-cursor-shaders/cursor_warp.glsl
