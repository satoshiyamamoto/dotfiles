{
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "prompts.chat@prompts.chat": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "repo": "max-sixty/worktrunk",
        "source": "github"
      }
    }
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tee /tmp/claude-permission.log | osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "language": "日本語",
  "permissions": {
    "allow": [
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(./mvnw:*)",
      "Bash(find:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mvn:*)",
      "Bash(npm audit:*)",
      "Bash(npm run:*)",
      "Bash(pnpm audit:*)",
      "Bash(pnpm run:*)",
      "Bash(uv audit:*)",
      "Bash(uv run:*)",
      "Read(//Users/**)",
      "Read(//opt/**)",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__context7__*",
      "mcp__plugin_github_github__*"
    ],
    "ask": [
      "Bash(gh issue create:*)",
      "Bash(gh pr create:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": []
  },
  "voiceEnabled": true
}
